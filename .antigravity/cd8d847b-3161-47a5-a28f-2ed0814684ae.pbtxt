      replacement_content: "@import url(\'https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@400;500;600;700&display=swap\');\n@import \"tailwindcss\";\n\n@theme {\n  --font-sans: \"Inter\", ui-sans-serif, system-ui, sans-serif;\n  --font-display: \"Space Grotesk\", sans-serif;\n  --font-mono: \"JetBrains Mono\", ui-monospace, SFMono-Regular, monospace;\n\n  /* Custom palette based on Raycast, Linear, Stripe */\n  --color-bg-base: #050816;\n  --color-surface: #0f172a;\n  --color-surface-card: #0f172aee;\n  --color-brand-primary: #38bdf8;\n  --color-brand-secondary: #8b5cf6;\n  --color-brand-accent: #c084fc;\n  --color-text-main: #f8fafc;\n  --color-text-muted: #94a3b8;\n}\n\n/* Base resets & adjustments */\nbody {\n  background-color: var(--color-bg-base);\n  color: var(--color-text-main);\n  font-family: var(--font-sans);\n  overflow-x: hidden;\n  margin: 0;\n  padding: 0;\n}\n\n/* Custom glow borders and glassmorphism elements */\n.glass-panel {\n  background: rgba(15, 23, 42, 0.65);\n  backdrop-filter: blur(14px);\n  -webkit-backdrop-filter: blur(14px);\n  border: 1px solid rgba(255, 255, 255, 0.08);\n}\n\n.glass-nav {\n  background: rgba(5, 8, 22, 0.7);\n  backdrop-filter: blur(16px);\n  -webkit-backdrop-filter: blur(16px);\n  border-bottom: 1px solid rgba(255, 255, 255, 0.05);\n}\n\n/* Custom scrollbar matching dark slate premium theme */\n::-webkit-scrollbar {\n  width: 8px;\n  height: 8px;\n}\n\n::-webkit-scrollbar-track {\n  background: #050816;\n}\n\n::-webkit-scrollbar-thumb {\n  background: #1e293b;\n  border-radius: 4px;\n}\n\n::-webkit-scrollbar-thumb:hover {\n  background: #334155;\n}\n\n/* Glowing accent effects */\n.glow-primary {\n  box-shadow: 0 0 40px -10px rgba(56, 189, 248, 0.35);\n}\n\n.glow-secondary {\n  box-shadow: 0 0 40px -10px rgba(139, 92, 246, 0.35);\n}\n\n.glow-text {\n  text-shadow: 0 0 12px rgba(56, 189, 248, 0.5);\n}\n\n/* Typing animation speed */\n.typing-cursor::after {\n  content: \'|\';\n  animation: blink 0.8s step-end infinite;\n}\n\n@keyframes blink {\n  from, to { color: transparent }\n  50% { color: var(--color-brand-primary) }\n}\n"
    }
