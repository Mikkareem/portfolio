  file_change {
    absolute_path_uri: "file:///src/pages/Projects.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState } from \'react\';\nimport { Link } from \'react-router-dom\';\nimport { motion } from \'motion/react\';\nimport { Github, ExternalLink, ArrowRight, Layers, Smartphone, Monitor, Cpu } from \'lucide-react\';\nimport { portfolioRepository } from \'../data/repositories/portfolioRepository\';\nimport { FadeIn, StaggerContainer, StaggerItem } from \'../components/animations/FadeIn\';\n\nexport const Projects = () => {\n  const [filter, setFilter] = useState<\'all\' | \'web\' | \'mobile\'>(\'all\');\n  \n  const allProjects = portfolioRepository.getProjects();\n  const majorProjects = allProjects.filter(p => p.type === \'major\');\n  const miniProjects = allProjects.filter(p => p.type === \'mini\');\n\n  const filteredMajorProjects = majorProjects.filter(p => {\n    if (filter === \'all\') return true;\n    if (filter === \'web\') return p.platform === \'web\' || p.platform === \'both\';\n    if (filter === \'mobile\') return p.platform === \'mobile\' || p.platform === \'both\';\n    return true;\n  });\n\n  const getPlatformIcon = (platform: \'web\' | \'mobile\' | \'both\') => {\n    if (platform === \'web\') return <Monitor className=\"w-4 h-4 text-brand-primary\" />;\n    if (platform === \'mobile\') return <Smartphone className=\"w-4 h-4 text-brand-accent\" />;\n    return <Layers className=\"w-4 h-4 text-brand-primary\" />;\n  };\n\n  return (\n    <div id=\"projects-page\" className=\"relative min-h-screen pt-28 pb-20 font-sans\">\n      \n      {/* Visual glowing effects */}\n      <div className=\"absolute top-1/4 right-0 w-[500px] h-[500px] bg-brand-primary/5 rounded-full blur-[140px] pointer-events-none\" />\n      <div className=\"absolute bottom-1/4 left-0 w-[450px] h-[450px] bg-brand-secondary/5 rounded-full blur-[140px] pointer-events-none\" />\n\n      <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full z-10 relative space-y-20\">\n        \n        {/* Page Title */}\n        <div className=\"flex flex-col md:flex-row md:items-end justify-between gap-6\">\n          <div className=\"max-w-3xl space-y-4\">\n            <FadeIn direction=\"up\">\n              <span className=\"text-xs font-mono font-bold tracking-widest text-brand-primary uppercase font-display\">DEVELOPER CATALOG</span>\n              <h1 className=\"text-4xl font-display font-extrabold tracking-tight text-white sm:text-5xl\">Engineered Solutions</h1>\n            </FadeIn>\n            <FadeIn direction=\"up\" delay={0.15}>\n              <p className=\"text-lg text-text-muted leading-relaxed\">\n                Dive deep into complex production ecosystems, cross-platform client builds, container registries, and declarative rendering structures.\n              </p>\n            </FadeIn>\n          </div>\n\n          {/* Filtering Tabs for Major projects */}\n          <FadeIn direction=\"up\">\n            <div className=\"flex p-1.5 rounded-xl bg-surface border border-white/5 shadow-md self-start md:self-end\">\n              {([\'all\', \'web\', \'mobile\'] as const).map(tab => (\n                <button\n                  key={tab}\n                  id={`filter-${tab}`}\n                  onClick={() => setFilter(tab)}\n                  className={`px-4 py-2 text-xs font-semibold uppercase tracking-wider rounded-lg transition-all duration-300 ${\n                    filter === tab\n                      ? \'bg-brand-primary text-black\'\n                      : \'text-text-muted hover:text-white\'\n                  }`}\n                >\n                  {tab}\n                </button>\n              ))}\n            </div>\n          </FadeIn>\n        </div>\n\n        {/* Major Projects Core System */}\n        <div className=\"space-y-10\">\n          <FadeIn direction=\"up\">\n            <h2 className=\"text-2xl font-display font-bold text-white flex items-center gap-2\">\n              <Cpu className=\"w-6 h-6 text-brand-primary\" /> Major Core Releases\n            </h2>\n          </FadeIn>\n\n          <StaggerContainer>\n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-8\">\n              {filteredMajorProjects.map((project, idx) => (\n                <StaggerItem key={project.id}>\n                  <div className=\"glass-panel rounded-2xl border-white/5 overflow-hidden flex flex-col h-full hover:border-brand-primary/30 hover:scale-[1.01] hover:shadow-2xl hover:shadow-brand-primary/5 transition-all duration-300 group\">\n                    \n                    {/* Media container */}\n                    <div className=\"h-64 overflow-hidden relative\">\n                      <img \n                        src={project.screenshots[0]} \n                        alt={project.title}\n                        referrerPolicy=\"no-referrer\"\n                        className=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\" \n                      />\n                      <div className=\"absolute top-4 right-4 bg-black/60 backdrop-blur-md border border-white/10 px-3 py-1 rounded-full text-xs font-semibold text-white capitalize flex items-center gap-1.5\">\n                        {getPlatformIcon(project.platform)}\n                        {project.platform === \'both\' ? \'Web & Mobile\' : project.platform}\n                      </div>\n                    </div>\n\n                    {/* Meta container */}\n                    <div className=\"p-6 sm:p-8 flex-grow flex flex-col justify-between space-y-6\">\n                      <div className=\"space-y-3\">\n                        <h3 className=\"text-xl font-bold font-display text-white group-hover:text-brand-primary transition-colors\">\n                          {project.title}\n                        </h3>\n                        <p className=\"text-sm text-text-muted leading-relaxed line-clamp-3\">\n                          {project.description}\n                        </p>\n                      </div>\n\n                      <div className=\"space-y-4 pt-4 border-t border-white/5\">\n                        {/* Stack tags */}\n                        <div className=\"flex flex-wrap gap-2\">\n                          {project.technologies.slice(0, 5).map(tech => (\n                            <span key={tech} className=\"px-2.5 py-1 text-xs font-mono text-brand-accent bg-brand-accent/5 border border-brand-accent/10 rounded-md\">\n                              {tech}\n                            </span>\n                          ))}\n                          {project.technologies.length > 5 && (\n                            <span className=\"px-2.5 py-1 text-xs font-mono text-text-muted bg-white/5 rounded-md\">\n                              +{project.technologies.length - 5} more\n                            </span>\n                          )}\n                        </div>\n\n                        {/* CTAs */}\n                        <div className=\"flex items-center justify-between pt-2\">\n                          <Link \n                            id={`view-specs-${project.id}`}\n                            to={`/project/${project.slug}`} \n                            className=\"text-sm font-semibold text-white hover:text-brand-primary transition-colors flex items-center gap-1.5\"\n                          >\n                            Specs &amp; Architecture\n                            <ArrowRight className=\"w-4 h-4 group-hover:translate-x-1.5 transition-transform\" />\n                          </Link>\n\n                          <div className=\"flex items-center space-x-3 text-text-muted\">\n                            {project.github && (\n                              <a \n                                id={`major-github-${project.id}`}\n                                href={project.github} \n                                target=\"_blank\" \n                                referrerPolicy=\"no-referrer\"\n                                className=\"p-2 rounded-lg bg-white/5 hover:text-brand-primary hover:bg-white/10 transition-all border border-transparent hover:border-brand-primary/10\"\n                                aria-label=\"GitHub Repo Link\"\n                              >\n                                <Github className=\"w-4 h-4\" />\n                              </a>\n                            )}\n                            {project.demo && (\n                              <a \n                                id={`major-demo-${project.id}`}\n                                href={project.demo} \n                                target=\"_blank\" \n                                referrerPolicy=\"no-referrer\"\n                                className=\"p-2 rounded-lg bg-white/5 hover:text-brand-primary hover:bg-white/10 transition-all border border-transparent hover:border-brand-primary/10\"\n                                aria-label=\"Live Stream Link\"\n                              >\n                                <ExternalLink className=\"w-4 h-4\" />\n                              </a>\n                            )}\n                          </div>\n                        </div>\n\n                      </div>\n                    </div>\n\n                  </div>\n                </StaggerItem>\n              ))}\n            </div>\n          </StaggerContainer>\n        </div>\n\n        {/* Mini Projects & UI Labs as Horizontal card streams */}\n        <div className=\"space-y-10 pt-10 border-t border-white/5\">\n          <FadeIn direction=\"up\">\n            <div className=\"space-y-2\">\n              <h2 className=\"text-2xl font-display font-bold text-white flex items-center gap-2\">\n                <Layers className=\"w-6 h-6 text-brand-primary\" /> Experimental Lab &amp; Mini Projects\n              </h2>\n              <p className=\"text-sm text-text-muted font-sans max-w-xl\">\n                Horizontal repository streams featuring UI layout labs, specialized Jetpack Compose animations, and canvas-intensive micro-visualizers.\n              </p>\n            </div>\n          </FadeIn>\n\n          <StaggerContainer staggerBy={0.1}>\n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n              {miniProjects.map((project, idx) => (\n                <StaggerItem key={project.id}>\n                  <div className=\"glass-panel p-6 rounded-2xl border-white/5 bg-surface-card hover:border-brand-secondary/30 transition-all duration-300 flex flex-col justify-between space-y-4 h-full group\">\n                    <div className=\"space-y-2\">\n                      <div className=\"flex items-center justify-between\">\n                        <span className=\"text-[10px] font-mono tracking-widest text-brand-accent uppercase bg-brand-accent/5 border border-brand-accent/10 px-2.5 py-0.5 rounded\">\n                          Animation Lab\n                        </span>\n                        {getPlatformIcon(project.platform)}\n                      </div>\n                      <h3 className=\"text-base font-bold font-display text-white group-hover:text-brand-primary transition-colors\">\n                        {project.title}\n                      </h3>\n                      <p className=\"text-sm text-text-muted leading-relaxed\">\n                        {project.description}\n                      </p>\n                    </div>\n\n                    <div className=\"flex items-center justify-between pt-2 border-t border-white/5\">\n                      <div className=\"flex flex-wrap gap-1.5\">\n                        {project.technologies.map(tech => (\n                          <span key={tech} className=\"px-2 py-0.5 text-[10px] font-mono bg-white/5 rounded text-text-muted\">\n                            {tech}\n                          </span>\n                        ))}\n                      </div>\n\n                      {project.github && (\n                        <a \n                          id={`mini-github-${project.id}`}\n                          href={project.github} \n                          target=\"_blank\" \n                          referrerPolicy=\"no-referrer\"\n                          className=\"text-text-muted hover:text-brand-primary transition-colors\"\n                          aria-label=\"Minis Repo\"\n                        >\n                          <Github className=\"w-4 h-4\" />\n                        </a>\n                      )}\n                    </div>\n                  </div>\n                </StaggerItem>\n              ))}\n            </div>\n          </StaggerContainer>\n        </div>\n\n      </div>\n    </div>\n  );\n};\nexport default Projects;\n"
    }
