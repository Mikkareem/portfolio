    instruction: "Add markdown-body styles to index.css"
    replacement_infos {
      original_chunk {
        target_content: "/* Typing animation speed */\n.typing-cursor::after {\n  content: \'|\';\n  animation: blink 0.8s step-end infinite;\n}\n\n@keyframes blink {\n  from, to { color: transparent }\n  50% { color: var(--color-brand-primary) }\n}"
        replacement_content: "/* Typing animation speed */\n.typing-cursor::after {\n  content: \'|\';\n  animation: blink 0.8s step-end infinite;\n}\n\n@keyframes blink {\n  from, to { color: transparent }\n  50% { color: var(--color-brand-primary) }\n}\n\n/* Premium Markdown Prose Styles */\n.markdown-body {\n  color: var(--color-text-main);\n  font-family: var(--font-sans);\n}\n\n.markdown-body h1 {\n  font-family: var(--font-display);\n  font-size: 2.25rem;\n  font-weight: 800;\n  letter-spacing: -0.025em;\n  color: #ffffff;\n  margin-top: 2rem;\n  margin-bottom: 1.25rem;\n  line-height: 1.2;\n}\n\n.markdown-body h2 {\n  font-family: var(--font-display);\n  font-size: 1.5rem;\n  font-weight: 700;\n  letter-spacing: -0.02em;\n  color: var(--color-brand-primary);\n  margin-top: 1.75rem;\n  margin-bottom: 1rem;\n  line-height: 1.3;\n}\n\n.markdown-body h3 {\n  font-family: var(--font-display);\n  font-size: 1.25rem;\n  font-weight: 600;\n  color: var(--color-brand-accent);\n  margin-top: 1.5rem;\n  margin-bottom: 0.75rem;\n}\n\n.markdown-body p {\n  font-size: 0.975rem;\n  line-height: 1.8;\n  color: var(--color-text-muted);\n  margin-bottom: 1.5rem;\n}\n\n.markdown-body pre {\n  background: rgba(15, 23, 42, 0.8);\n  border: 1px solid rgba(255, 255, 255, 0.08);\n  padding: 1.25rem;\n  border-radius: 0.75rem;\n  overflow-x: auto;\n  font-family: var(--font-mono);\n  font-size: 0.85rem;\n  margin: 1.5rem 0;\n  box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.3);\n}\n\n.markdown-body code {\n  font-family: var(--font-mono);\n  font-size: 0.8rem;\n  background: rgba(139, 92, 246, 0.1);\n  border: 1px solid rgba(139, 92, 246, 0.2);\n  padding: 0.15rem 0.35rem;\n  border-radius: 0.25rem;\n  color: var(--color-brand-accent);\n}\n\n.markdown-body pre code {\n  background: none;\n  border: none;\n  padding: 0;\n  color: #e2e8f0;\n}\n\n.markdown-body ul {\n  list-style-type: disc;\n  padding-left: 1.5rem;\n  margin-bottom: 1.5rem;\n  color: var(--color-text-muted);\n  line-height: 1.8;\n}\n\n.markdown-body ul li {\n  margin-bottom: 0.5rem;\n}\n\n.markdown-body blockquote {\n  border-left: 3px solid var(--color-brand-primary);\n  padding-left: 1rem;\n  margin-left: 0;\n  font-style: italic;\n  color: #cbd5e1;\n  background: rgba(56, 189, 248, 0.03);\n  padding-top: 0.5rem;\n  padding-bottom: 0.5rem;\n  border-radius: 0 0.5rem 0.5rem 0;\n}\n"
      }
      num_matches: 1
    }
  }
