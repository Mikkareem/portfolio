    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { Project } from \'../types\';\n\nexport const projectsData: Project[] = [\n  // Major Projects\n  {\n    id: \'codehorn\',\n    title: \'Codehorn\',\n    slug: \'codehorn\',\n    type: \'major\',\n    description: \'A revolutionary, real-time collaborative coding and developer social hub. Engineered with advanced multi-terminal sync, containerized code execution pools, and immersive dashboard layouts.\',\n    overview: \'Codehorn bridges the gap between collaborative workspaces and coding communities. It allows groups of users to instantiate lightning-fast Sandboxes, write Spring Boot/Kotlin, compile within sandboxed clusters, and compare algorithmic paths. Built on high-performance message queues and full reactive styling.\',\n    technologies: [\'ReactJS\', \'TypeScript\', \'Spring Boot\', \'Kotlin\', \'Docker\', \'Kubernetes\', \'AWS\', \'TailwindCSS\'],\n    github: \'https://github.com/mohdirsath1997/codehorn-workspace\',\n    demo: \'https://codehorn.dev\',\n    screenshots: [\n      \'https://images.unsplash.com/photo-1542831371-29b0f74f9713?auto=format&fit=crop&q=80&w=600\',\n      \'https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&q=80&w=600\'\n    ],\n    platform: \'web\'\n  },\n  {\n    id: \'notemyshow\',\n    title: \'NoteMyShow\',\n    slug: \'notemyshow\',\n    type: \'major\',\n    description: \'A comprehensive, high-fidelity online entertainment ticket and cinema reservation system. Implements interactive 3D seat selection maps, multi-tenant vendor billing pipelines, and instant offline booking passes.\',\n    overview: \'NoteMyShow provides full theatrical seat scheduling, live concurrency locks, and localized notification alerts for pre-registered films. Features include an interactive seating grid with hardware acceleration and deep Kotlin/Multiplatform optimizations for mobile companion utilities.\',\n    technologies: [\'ReactJS\', \'TypeScript\', \'Java\', \'Spring Cloud\', \'SQL\', \'Terraform\', \'ArgoCD\', \'NextJS\'],\n    github: \'https://github.com/mohdirsath1997/notemyshow-platform\',\n    demo: \'https://notemyshow.info\',\n    screenshots: [\n      \'https://images.unsplash.com/photo-1517604931442-7e0c8ed2963c?auto=format&fit=crop&q=80&w=600\',\n      \'https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?auto=format&fit=crop&q=80&w=600\'\n    ],\n    platform: \'both\'\n  },\n  // Mobile App Collections\n  {\n    id: \'fitpulse\',\n    title: \'FitPulse Engine\',\n    slug: \'fitpulse\',\n    type: \'major\',\n    description: \'A modern, lightweight cardiac tracking and health assistant app. Designed with fully native Jetpack Compose animations, canvas pulse lines, and secure local SQL storage.\',\n    overview: \'FitPulse tracks daily heart telemetry and integrates with custom health wearables. Utilizes Koin for dependency management, Room DB for secure sensor logs, and standard Kotlin Multiplatform pipelines to run on iOS and Android concurrently.\',\n    technologies: [\'Kotlin Multiplatform\', \'Jetpack Compose\', \'Koin\', \'Room\', \'Ktor\', \'Coil\'],\n    github: \'https://github.com/mohdirsath1997/fitpulse-kmp\',\n    demo: \'https://fitpulse.app\',\n    screenshots: [\n      \'https://images.unsplash.com/photo-1510017808638-a59b57144825?auto=format&fit=crop&q=80&w=600\',\n      \'https://images.unsplash.com/photo-1522881195387-3970343a5899?auto=format&fit=crop&q=80&w=600\'\n    ],\n    platform: \'mobile\'\n  },\n  {\n    id: \'finflow-wallet\',\n    title: \'FinFlow Wallet\',\n    slug: \'finflow-wallet\',\n    type: \'major\',\n    description: \'A high-contrast mobile ledger and crypto vault visualizer built with Compose Multiplatform. Implements custom drag physics, canvas charts, and real-time exchange socket pipelines.\',\n    overview: \'FinFlow displays interactive multi-currency ledger stats. It employs custom Jetpack Compose canvas visual states, custom layout gestures, and responsive animations to offer high-fidelity transaction feedback.\',\n    technologies: [\'Kotlin Multiplatform\', \'Compose Multiplatform\', \'Ktor\', \'Koin\', \'Room\'],\n    github: \'https://github.com/mohdirsath1997/finflow-wallet\',\n    demo: \'https://finflow.io\',\n    screenshots: [\n      \'https://images.unsplash.com/photo-1621761191319-c6fb62004040?auto=format&fit=crop&q=80&w=600\',\n      \'https://images.unsplash.com/photo-1559526324-4b87b5e36e44?auto=format&fit=crop&q=80&w=600\'\n    ],\n    platform: \'mobile\'\n  },\n\n  // Mini Projects for Layout & Animation experiments\n  {\n    id: \'jetpack-compose-animations\',\n    title: \'Jetpack Compose Animations Lab\',\n    slug: \'compose-animations-lab\',\n    type: \'mini\',\n    description: \'A experimental laboratory of core Compose animation states (animateContentSize, custom Transitions, physical offsets, and canvas-rendered vector splines).\',\n    overview: \'\',\n    technologies: [\'Jetpack Compose\', \'Kotlin\', \'Compose Multiplatform\'],\n    github: \'https://github.com/mohdirsath1997/compose-animation-lab\',\n    screenshots: [],\n    platform: \'mobile\'\n  },\n  {\n    id: \'custom-layout-experiments\',\n    title: \'Custom Layout Experiments\',\n    slug: \'custom-layouts-experiments\',\n    type: \'mini\',\n    description: \'Highly customized layout pipelines exploring Android Layout managers, canvas measures, custom grid overlays, and multi-axis scrolling gestures.\',\n    overview: \'\',\n    technologies: [\'Jetpack Compose\', \'Java\', \'Kotlin\'],\n    github: \'https://github.com/mohdirsath1997/custom-layouts\',\n    screenshots: [],\n    platform: \'mobile\'\n  },\n  {\n    id: \'compose-multiplatform-ui\',\n    title: \'Compose Multiplatform UI Showcases\',\n    slug: \'compose-multi-ui\',\n    type: \'mini\',\n    description: \'An expansive open-source catalogue of UI packages replicating high-end Vercel and Stripe web transitions inside mobile viewports.\',\n    overview: \'\',\n    technologies: [\'Compose Multiplatform\', \'KMP\', \'Kotlin\'],\n    github: \'https://github.com/mohdirsath1997/compose-showcases\',\n    screenshots: [],\n    platform: \'mobile\'\n  },\n  {\n    id: \'animation-labs\',\n    title: \'Animation Labs (Web & Canvas)\',\n    slug: \'animation-labs\',\n    type: \'mini\',\n    description: \'A canvas-intensive visual laboratory testing spring-mass systems, custom SVG paths, p5.js integrations, and fluid CSS transform timelines.\',\n    overview: \'\',\n    technologies: [\'ReactJS\', \'TypeScript\', \'TailwindCSS\', \'motion\'],\n    github: \'https://github.com/mohdirsath1997/web-animation-labs\',\n    screenshots: [],\n    platform: \'web\'\n  }\n];\n"
    }
