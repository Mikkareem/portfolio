    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState, useEffect } from \'react\';\nimport { Link } from \'react-router-dom\';\nimport { motion } from \'motion/react\';\nimport { ArrowRight, Code2, Smartphone, Terminal, Cpu, ArrowUpRight } from \'lucide-react\';\nimport { portfolioRepository } from \'../data/repositories/portfolioRepository\';\nimport { FadeIn, StaggerContainer, StaggerItem } from \'../components/animations/FadeIn\';\n\nexport const Home = () => {\n  const profile = portfolioRepository.getProfile();\n  const majorProjects = portfolioRepository.getProjects(\'major\').slice(0, 2);\n  \n  // Real-time developer typing sequence\n  const roles = [\n    \"Full Stack Web Developer\",\n    \"Mobile App Developer\",\n    \"Cloud Native Specialist\",\n    \"DevOps Practitioner\"\n  ];\n  \n  const [currentRoleIndex, setCurrentRoleIndex] = useState(0);\n  const [currentText, setCurrentText] = useState(\"\");\n  const [isDeleting, setIsDeleting] = useState(false);\n  const [typingSpeed, setTypingSpeed] = useState(100);\n\n  useEffect(() => {\n    let timer: NodeJS.Timeout;\n    const fullText = roles[currentRoleIndex];\n\n    const handleType = () => {\n      if (!isDeleting) {\n        // Typing\n        setCurrentText(fullText.substring(0, currentText.length + 1));\n        setTypingSpeed(80);\n        \n        if (currentText === fullText) {\n          // Pause at end\n          timer = setTimeout(() => setIsDeleting(true), 2000);\n          return;\n        }\n      } else {\n        // Deleting\n        setCurrentText(fullText.substring(0, currentText.length - 1));\n        setTypingSpeed(40);\n        \n        if (currentText === \"\") {\n          setIsDeleting(false);\n          setCurrentRoleIndex((prev) => (prev + 1) % roles.length);\n          setTypingSpeed(500); // Pause before next word\n          return;\n        }\n      }\n\n      timer = setTimeout(handleType, typingSpeed);\n    };\n\n    timer = setTimeout(handleType, typingSpeed);\n    return () => clearTimeout(timer);\n  }, [currentText, isDeleting, currentRoleIndex, typingSpeed]);\n\n  return (\n    <div id=\"home-page\" className=\"relative min-h-screen pt-28 pb-16 overflow-hidden flex flex-col justify-center\">\n      \n      {/* Visual glowing meshes */}\n      <div className=\"absolute top-1/4 right-1/4 w-[300px] sm:w-[450px] h-[300px] sm:h-[450px] bg-brand-primary/10 rounded-full blur-[100px] pointer-events-none\" />\n      <div className=\"absolute bottom-1/4 left-1/4 w-[350px] h-[350px] bg-brand-secondary/10 rounded-full blur-[120px] pointer-events-none\" />\n\n      <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full z-10\">\n        \n        {/* Core Hero Section */}\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-center min-h-[60vh]\">\n          \n          <div className=\"lg:col-span-7 space-y-6 text-left\">\n            <FadeIn direction=\"up\" delay={0.1}>\n              <div className=\"inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-white/5 bg-surface-card text-brand-primary text-xs font-semibold tracking-wider font-mono\">\n                <span className=\"flex h-2 w-2 relative\">\n                  <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-primary opacity-75\"></span>\n                  <span className=\"relative inline-flex rounded-full h-2 w-2 bg-brand-primary\"></span>\n                </span>\n                AVAILABLE FOR NEW OPPORTUNITIES\n              </div>\n            </FadeIn>\n\n            <FadeIn direction=\"up\" delay={0.25}>\n              <h1 className=\"text-4xl sm:text-5xl md:text-6xl font-display font-extrabold tracking-tight text-white leading-[1.12]\">\n                Hi, I am <br />\n                <span className=\"bg-gradient-to-r from-brand-primary via-brand-accent to-brand-secondary bg-clip-text text-transparent hover:glow-text transition-all duration-300\">\n                  {profile.name}\n                </span>\n              </h1>\n            </FadeIn>\n\n            <FadeIn direction=\"up\" delay={0.35}>\n              <div className=\"h-8 md:h-10\">\n                <span className=\"text-xl sm:text-2xl md:text-3xl text-text-muted font-display font-semibold typing-cursor\">\n                  {currentText}\n                </span>\n              </div>\n            </FadeIn>\n\n            <FadeIn direction=\"up\" delay={0.45}>\n              <p className=\"text-base sm:text-lg text-text-muted font-sans max-w-xl leading-relaxed\">\n                {profile.tagline} {profile.bio}\n              </p>\n            </FadeIn>\n\n            {/* CTAs */}\n            <FadeIn direction=\"up\" delay={0.55}>\n              <div className=\"flex flex-wrap items-center gap-4 pt-4\">\n                <Link\n                  id=\"hero-cta-projects\"\n                  to=\"/projects\"\n                  className=\"flex items-center gap-2 px-6 py-3.5 bg-brand-primary text-black font-semibold rounded-full hover:bg-brand-primary/95 hover:scale-105 active:scale-95 transition-all duration-300 font-sans shadow-lg shadow-brand-primary/10\"\n                >\n                  <span>Explore Projects</span>\n                  <ArrowRight className=\"w-4 h-4\" />\n                </Link>\n                <Link\n                  id=\"hero-cta-blogs\"\n                  to=\"/blogs\"\n                  className=\"flex items-center gap-2 px-6 py-3.5 border border-white/10 bg-surface-card text-white font-semibold rounded-full hover:bg-white/5 hover:border-white/20 hover:scale-105 active:scale-95 transition-all duration-300 font-sans\"\n                >\n                  <span>Read Blogs</span>\n                  <ArrowUpRight className=\"w-4 h-4\" />\n                </Link>\n                <Link\n                  id=\"hero-cta-contact\"\n                  to=\"/contact\"\n                  className=\"flex items-center gap-2 px-6 py-3.5 text-text-muted hover:text-white transition-all font-semibold font-sans text-sm\"\n                >\n                  Contact Me\n                </Link>\n              </div>\n            </FadeIn>\n          </div>\n\n          {/* Interactive Bento Card/Visual Component on right */}\n          <div className=\"lg:col-span-5 relative mt-6 lg:mt-0\">\n            <FadeIn direction=\"left\" delay={0.4} scale={true}>\n              <div className=\"glass-panel rounded-2xl p-6 sm:p-8 space-y-6 shadow-2xl relative border-white/10 bg-surface-card glow-secondary\">\n                \n                {/* Simulated terminal */}\n                <div className=\"flex items-center justify-between border-b border-white/5 pb-4\">\n                  <div className=\"flex items-center space-x-2\">\n                    <span className=\"w-3 h-3 rounded-full bg-red-500/80\" />\n                    <span className=\"w-3 h-3 rounded-full bg-yellow-500/80\" />\n                    <span className=\"w-3 h-3 rounded-full bg-green-500/80\" />\n                  </div>\n                  <span className=\"text-xs font-mono text-text-muted\">bash ~ main.sh</span>\n                </div>\n\n                <div className=\"space-y-4 font-mono text-xs sm:text-sm text-text-muted\">\n                  <p>\n                    <span className=\"text-brand-primary\">&gt;</span> mohamed.init()\n                  </p>\n                  <p className=\"text-brand-accent\">\n                    &quot;Deploying cloud native instances...&quot;\n                  </p>\n                  <div className=\"p-3 bg-black/40 rounded-lg border border-white/5 space-y-2\">\n                    <p className=\"text-green-400 flex items-center gap-2\">\n                      <Code2 className=\"w-4 h-4\" /> Web Layer: Active (ReactJS/Vite)\n                    </p>\n                    <p className=\"text-green-400 flex items-center gap-2\">\n                      <Smartphone className=\"w-4 h-4\" /> Mobile Layer: Active (KMP/Compose)\n                    </p>\n                    <p className=\"text-brand-primary flex items-center gap-2\">\n                      <Cpu className=\"w-4 h-4\" /> Infra Mesh: Up (EKS/Docker)\n                    </p>\n                  </div>\n                  <p>\n                    <span className=\"text-brand-primary\">&gt;</span> mohamed.getStats()\n                  </p>\n                  <p className=\"text-white\">\n                    &#123; experience: &quot;{profile.yearsExperience}+ Years&quot;, projects: {profile.projectsBuiltCount} &#125;\n                  </p>\n                </div>\n              </div>\n            </FadeIn>\n          </div>\n        </div>\n\n        {/* Counter Statistics Section */}\n        <div className=\"mt-16 md:mt-24 pt-10 border-t border-white/5\">\n          <StaggerContainer>\n            <div className=\"grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-10\">\n              \n              <StaggerItem>\n                <div className=\"glass-panel p-5 sm:p-6 rounded-2xl text-center space-y-2 border-white/5 hover:border-brand-primary/20 hover:scale-[1.02] transition-all duration-300\">\n                  <h3 className=\"text-3xl sm:text-4xl font-display font-extrabold text-brand-primary\">\n                    {profile.yearsExperience}+\n                  </h3>\n                  <p className=\"text-xs sm:text-sm font-sans text-text-muted font-medium\">Years Experience</p>\n                </div>\n              </StaggerItem>\n\n              <StaggerItem>\n                <div className=\"glass-panel p-5 sm:p-6 rounded-2xl text-center space-y-2 border-white/5 hover:border-brand-accent/20 hover:scale-[1.02] transition-all duration-300\">\n                  <h3 className=\"text-3xl sm:text-4xl font-display font-extrabold text-brand-accent\">\n                    {profile.projectsBuiltCount}+\n                  </h3>\n                  <p className=\"text-xs sm:text-sm font-sans text-text-muted font-medium\">Projects Built</p>\n                </div>\n              </StaggerItem>\n\n              <StaggerItem>\n                <div className=\"glass-panel p-5 sm:p-6 rounded-2xl text-center space-y-2 border-white/5 hover:border-brand-secondary/20 hover:scale-[1.02] transition-all duration-300\">\n                  <h3 className=\"text-3xl sm:text-4xl font-display font-extrabold text-color-brand-secondary\">\n                    {profile.articlesCount}+\n                  </h3>\n                  <p className=\"text-xs sm:text-sm font-sans text-text-muted font-medium\">Articles Written</p>\n                </div>\n              </StaggerItem>\n\n              <StaggerItem>\n                <div className=\"glass-panel p-5 sm:p-6 rounded-2xl text-center space-y-2 border-white/5 hover:border-brand-primary/20 hover:scale-[1.02] transition-all duration-300\">\n                  <h3 className=\"text-3xl sm:text-4xl font-display font-extrabold text-brand-primary\">\n                    {profile.technologiesCount}+\n                  </h3>\n                  <p className=\"text-xs sm:text-sm font-sans text-text-muted font-medium\">Tech & Systems</p>\n                </div>\n              </StaggerItem>\n\n            </div>\n          </StaggerContainer>\n        </div>\n\n        {/* Featured Projects Highlights */}\n        <div className=\"mt-28 md:mt-36 space-y-12\">\n          \n          <div className=\"flex flex-col sm:flex-row items-start sm:items-end justify-between gap-4\">\n            <FadeIn direction=\"up\">\n              <div className=\"space-y-2\">\n                <span className=\"text-xs font-mono font-bold tracking-widest text-brand-primary uppercase\">SELECTED SHOWCASE</span>\n                <h2 className=\"text-3xl font-display font-bold text-white\">Major Core Systems</h2>\n              </div>\n            </FadeIn>\n            \n            <FadeIn direction=\"up\">\n              <Link id=\"view-all-projects-home\" to=\"/projects\" className=\"group flex items-center gap-2 text-sm font-semibold tracking-wide text-white hover:text-brand-primary transition-colors\">\n                View Project Catalog\n                <ArrowRight className=\"w-4 h-4 group-hover:translate-x-1.5 transition-transform\" />\n              </Link>\n            </FadeIn>\n          </div>\n\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-8 font-sans\">\n            {majorProjects.map((project, idx) => (\n              <FadeIn key={project.id} direction=\"up\" delay={idx * 0.15}>\n                <div className=\"glass-panel rounded-2xl border-white/5 overflow-hidden flex flex-col h-full hover:border-brand-secondary/30 hover:scale-[1.01] transition-all duration-300 group\">\n                  <div className=\"h-60 overflow-hidden relative\">\n                    <img \n                      src={project.screenshots[0]} \n                      alt={project.title}\n                      referrerPolicy=\"no-referrer\"\n                      className=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\" \n                    />\n                    <div className=\"absolute top-4 right-4 bg-black/60 backdrop-blur-md border border-white/10 px-3 py-1 rounded-full text-xs font-semibold text-brand-primary capitalize\">\n                      {project.platform === \'both\' ? \'Web & Mobile\' : project.platform}\n                    </div>\n                  </div>\n                  \n                  <div className=\"p-6 sm:p-8 flex-grow flex flex-col justify-between space-y-4\">\n                    <div className=\"space-y-2\">\n                      <h3 className=\"text-xl font-bold font-display text-white group-hover:text-brand-primary transition-colors\">\n                        {project.title}\n                      </h3>\n                      <p className=\"text-sm text-text-muted leading-relaxed line-clamp-3\">\n                        {project.description}\n                      </p>\n                    </div>\n\n                    <div className=\"space-y-4 pt-4\">\n                      <div className=\"flex flex-wrap gap-2\">\n                        {project.technologies.slice(0, 4).map(tech => (\n                          <span key={tech} className=\"px-2.5 py-1 text-xs font-mono text-brand-accent bg-brand-accent/5 border border-brand-accent/10 rounded-md\">\n                            {tech}\n                          </span>\n                        ))}\n                        {project.technologies.length > 4 && (\n                          <span className=\"px-2.5 py-1 text-xs font-mono text-text-muted bg-white/5 rounded-md\">\n                            +{project.technologies.length - 4} more\n                          </span>\n                        )}\n                      </div>\n                      \n                      <div className=\"flex items-center gap-4 text-sm font-semibold\">\n                        <Link \n                          id={`proj-view-details-${project.id}`}\n                          to={`/project/${project.slug}`} \n                          className=\"text-white hover:text-brand-primary transition-colors\"\n                        >\n                          Specs &amp; Architecture\n                        </Link>\n                        {project.demo && (\n                          <a \n                            id={`proj-living-app-${project.id}`}\n                            href={project.demo} \n                            target=\"_blank\" \n                            referrerPolicy=\"no-referrer\"\n                            className=\"text-text-muted hover:text-brand-primary flex items-center gap-1 transition-colors\"\n                          >\n                            Live Build <ArrowUpRight className=\"w-3.5 h-3.5\" />\n                          </a>\n                        )}\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </FadeIn>\n            ))}\n          </div>\n\n        </div>\n\n      </div>\n    </div>\n  );\n};\nexport default Home;\n"
    }
