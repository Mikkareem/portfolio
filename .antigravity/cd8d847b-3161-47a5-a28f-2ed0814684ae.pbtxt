      replacement_content: "        {/* Collective Orbital Skills Block */}\n        <div className=\"mt-28 md:mt-36 space-y-12\">\n          <div className=\"max-w-3xl space-y-4\">\n            <FadeIn direction=\"up\">\n              <span className=\"text-xs font-mono font-bold tracking-widest text-[#38bdf8] uppercase\">CORE COMPETENCIES</span>\n              <h2 className=\"text-3xl font-display font-bold text-white\">Technological <span className=\"text-gradient\">Orbit</span></h2>\n            </FadeIn>\n            <FadeIn direction=\"up\" delay={0.15}>\n              <p className=\"text-sm md:text-base text-[#94a3b8] leading-relaxed\">\n                Interact with the floating core system nodes to discover architectural expertise. Centered around major declarative, cross-platform, enterprise microservices, and state engines.\n              </p>\n            </FadeIn>\n          </div>\n\n          <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-center\">\n            \n            {/* Left Column: Floating Orbital Arena (6 Columns) */}\n            <div className=\"lg:col-span-6 flex items-center justify-center relative min-h-[440px] sm:min-h-[480px]\">\n              \n              {/* Outer Orbit Dotted Ring */}\n              <div className=\"absolute w-[280px] h-[280px] rounded-full border border-dashed border-white/10 animate-[spin_50s_linear_infinite]\" />\n              <div className=\"absolute w-[360px] h-[360px] rounded-full border border-dashed border-white/5 animate-[spin_80s_linear_infinite_reverse]\" />\n              \n              {/* Central Sun Node */}\n              <div className=\"absolute w-28 h-28 rounded-full bg-gradient-to-br from-[#38bdf8]/15 to-[#8b5cf6]/15 border border-white/15 flex flex-col items-center justify-center text-center shadow-2xl relative z-10 hover:border-[#38bdf8]/30 transition-all duration-300 glow-blue group cursor-pointer select-none\">\n                <div className=\"absolute inset-0 rounded-full bg-gradient-to-tr from-[#38bdf8]/5 to-[#8b5cf6]/5 animate-pulse\" />\n                <span className=\"text-[10px] font-mono text-[#38bdf8] uppercase tracking-widest font-extrabold relative z-10\">M.I.K</span>\n                <span className=\"text-xs font-mono text-[#8b5cf6] font-bold tracking-tight relative z-10 uppercase\">CORE STACK</span>\n              </div>\n\n              {/* Floating Orbiting Nodes */}\n              {orbitSkills.map((skill, idx) => {\n                const angle = (idx / orbitSkills.length) * 2 * Math.PI - Math.PI / 2; // offset starting point\n                const radius = 135; // orbit radius\n                const x = Math.cos(angle) * radius;\n                const y = Math.sin(angle) * radius;\n                const IconComponent = skill.icon;\n                const isSelected = selectedSkillIndex === idx;\n\n                return (\n                  <motion.button\n                    key={skill.name}\n                    id={`floating-skill-node-${idx}`}\n                    onClick={() => setSelectedSkillIndex(idx)}\n                    className={`absolute p-3.5 rounded-full border flex items-center justify-center transition-all duration-300 group ${\n                      isSelected\n                        ? \'bg-gradient-to-br from-[#38bdf8] to-[#8b5cf6] text-[#050816] border-[#38bdf8] shadow-lg shadow-[#38bdf8]/20 scale-110 z-20\'\n                        : \'bg-black/60 text-white/80 border-white/10 hover:border-[#38bdf8] hover:text-white hover:scale-[1.08] z-10\'\n                    }`}\n                    style={{ left: `calc(50% + ${x}px - 26px)`, top: `calc(50% + ${y}px - 26px)` }}\n                    animate={{\n                      x: [0, (idx % 2 === 0 ? 5 : -5), (idx % 3 === 0 ? -4 : 4), 0],\n                      y: [0, (idx % 2 === 0 ? -6 : 6), (idx % 3 === 0 ? 4 : -4), 0],\n                    }}\n                    transition={{\n                      duration: 6 + (idx % 3) * 2,\n                      repeat: Infinity,\n                      ease: \"easeInOut\"\n                    }}\n                    whileTap={{ scale: 0.95 }}\n                  >\n                    <IconComponent className=\"w-5 h-5 shrink-0\" />\n                    \n                    {/* Tiny visual connecting line */}\n                    <div className={`absolute w-[1.5px] bg-gradient-to-b from-transparent to-white/10 hidden lg:block origin-bottom pointer-events-none transition-opacity ${\n                      isSelected ? \'opacity-30\' : \'opacity-10\'\n                    }`}\n                    style={{\n                      height: `${radius}px`,\n                      bottom: \'50%\',\n                      transform: `rotate(${-angle * (180 / Math.PI) + 90}deg)`\n                    }} />\n\n                    {/* Tooltip on Hover */}\n                    <span className=\"absolute bottom-full mb-2 bg-slate-950 text-white text-[10px] font-mono px-2 py-1 rounded border border-white/10 opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none select-none z-30 shadow-xl\">\n                      {skill.name}\n                    </span>\n                  </motion.button>\n                );\n              })}\n\n            </div>\n\n            {/* Right Column: Detailed Skill Metrics Showcase (6 Columns) */}\n            <div className=\"lg:col-span-6 space-y-6\">\n              <div className=\"glass-panel p-6 sm:p-8 rounded-2xl border-white/5 bg-surface-card shadow-xl space-y-6 relative overflow-hidden min-h-[360px] flex flex-col justify-between\">\n                \n                <div className=\"space-y-4\">\n                  <div className=\"flex items-center justify-between border-b border-white/5 pb-4\">\n                    <div className=\"flex items-center space-x-3\">\n                      <div className=\"p-2 rounded bg-white/5 border border-white/10\">\n                        {(() => {\n                          const IconComp = orbitSkills[selectedSkillIndex].icon;\n                          return <IconComp className=\"w-5 h-5 text-[#38bdf8]\" />;\n                        })()}\n                      </div>\n                      <div>\n                        <span className=\"text-[10px] font-mono uppercase text-[#38bdf8] font-bold tracking-widest block\">\n                          {orbitSkills[selectedSkillIndex].tag}\n                        </span>\n                        <h3 className=\"text-xl font-bold text-white tracking-wide\">\n                          {orbitSkills[selectedSkillIndex].name}\n                        </h3>\n                      </div>\n                    </div>\n                    <span className=\"text-xs font-mono font-bold bg-[#38bdf8]/10 text-[#38bdf8] border border-[#38bdf8]/20 px-2.5 py-1 rounded-full\">\n                      Level: {orbitSkills[selectedSkillIndex].level}%\n                    </span>\n                  </div>\n\n                  <p className=\"text-sm text-[#94a3b8] leading-relaxed min-h-[64px]\">\n                    {orbitSkills[selectedSkillIndex].longDesc}\n                  </p>\n\n                  <div className=\"space-y-2 pt-2\">\n                    <span className=\"text-xs font-mono text-white/50 block\">Associated Architecture &amp; Concepts</span>\n                    <div className=\"flex flex-wrap gap-2\">\n                      {orbitSkills[selectedSkillIndex].concepts.map(concept => (\n                        <span key={concept} className=\"text-xs px-2.5 py-1 rounded bg-[#050816]/60 border border-white/5 text-white/80\">\n                          {concept}\n                        </span>\n                      ))}\n                    </div>\n                  </div>\n                </div>\n\n                <div className=\"grid grid-cols-2 gap-4 pt-4 border-t border-white/5\">\n                  <button \n                    onClick={() => {\n                      setSelectedSkillIndex((prev) => (prev - 1 + orbitSkills.length) % orbitSkills.length);\n                    }}\n                    className=\"py-2.5 px-4 text-xs font-mono font-bold border border-white/5 hover:border-white/10 bg-slate-900/40 text-[#94a3b8] hover:text-white rounded-lg transition-all text-center flex items-center justify-center gap-2\"\n                  >\n                    &larr; Prev Skill\n                  </button>\n                  <button \n                    onClick={() => {\n                      setSelectedSkillIndex((prev) => (prev + 1) % orbitSkills.length);\n                    }}\n                    className=\"py-2.5 px-4 text-xs font-mono font-bold border border-white/5 hover:border-[#38bdf8] bg-slate-900/40 text-white hover:text-[#38bdf8] rounded-lg transition-all text-center flex items-center justify-center gap-2\"\n                  >\n                    Next Skill &rarr;\n                  </button>\n                </div>\n\n              </div>\n              \n              {/* Click instruction */}\n              <p className=\"text-center lg:text-left text-xs text-[#94a3b8]/60 font-mono\">\n                \360\237\222\241 Tip: Click on any hovering icon in the technology orbit to explore.\n              </p>\n            </div>\n\n          </div>\n        </div>\n\n        {/* Featured Projects Highlights */}\n        <div className=\"mt-28 md:mt-36 space-y-12\">"
    }
