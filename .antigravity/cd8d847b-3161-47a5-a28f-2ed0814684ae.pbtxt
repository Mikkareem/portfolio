    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState, FormEvent } from \'react\';\nimport { motion, AnimatePresence } from \'motion/react\';\nimport { Mail, Github, Linkedin, MessageSquare, Send, CheckCircle2, AlertCircle } from \'lucide-react\';\nimport { portfolioRepository } from \'../data/repositories/portfolioRepository\';\nimport { FadeIn } from \'../components/animations/FadeIn\';\n\nexport const Contact = () => {\n  const profile = portfolioRepository.getProfile();\n\n  // State Management\n  const [name, setName] = useState(\'\');\n  const [email, setEmail] = useState(\'\');\n  const [subject, setSubject] = useState(\'\');\n  const [message, setMessage] = useState(\'\');\n  \n  // Validation and Statuses\n  const [errors, setErrors] = useState<{ [key: string]: string }>({});\n  const [isSubmitting, setIsSubmitting] = useState(false);\n  const [isSuccess, setIsSuccess] = useState(false);\n\n  const validate = () => {\n    const tempErrors: { [key: string]: string } = {};\n    if (!name.trim()) tempErrors.name = \'Please provide your name.\';\n    if (!email.trim()) {\n      tempErrors.email = \'Please provide an email address.\';\n    } else if (!/\\S+@\\S+\\.\\S+/.test(email)) {\n      tempErrors.email = \'Please provide a valid email format sample: name@domain.com.\';\n    }\n    if (!subject.trim()) tempErrors.subject = \'Please specify a subject.\';\n    if (!message.trim()) tempErrors.message = \'Please write a brief message body.\';\n    \n    setErrors(tempErrors);\n    return Object.keys(tempErrors).length === 0;\n  };\n\n  const handleSend = async (e: FormEvent) => {\n    e.preventDefault();\n    if (!validate()) return;\n\n    setIsSubmitting(true);\n    \n    // Simulate a high-fidelity delivery pipeline delay\n    setTimeout(() => {\n      setIsSubmitting(false);\n      setIsSuccess(true);\n      // Reset form fields\n      setName(\'\');\n      setEmail(\'\');\n      setSubject(\'\');\n      setMessage(\'\');\n    }, 1800);\n  };\n\n  return (\n    <div id=\"contact-page\" className=\"relative min-h-screen pt-28 pb-20 font-sans\">\n      \n      {/* Background decorations */}\n      <div className=\"absolute top-1/4 right-[10%] w-96 h-96 bg-brand-primary/5 rounded-full blur-[100px] pointer-events-none\" />\n      <div className=\"absolute bottom-1/4 left-[10%] w-96 h-96 bg-brand-secondary/5 rounded-full blur-[100px] pointer-events-none\" />\n\n      <div className=\"max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 space-y-16\">\n        \n        {/* Header Segment */}\n        <div className=\"max-w-3xl space-y-4\">\n          <FadeIn direction=\"up\">\n            <span className=\"text-xs font-mono font-bold tracking-widest text-brand-primary uppercase font-display\">GET IN TOUCH</span>\n            <h1 className=\"text-4xl font-display font-extrabold tracking-tight text-white sm:text-5xl\">Commence Dialogue</h1>\n          </FadeIn>\n          <FadeIn direction=\"up\" delay={0.15}>\n            <p className=\"text-lg text-text-muted leading-relaxed\">\n              Have a complex architectural project in pipeline, looking to deploy cross-platform systems, or simply want to chat? Write a line below.\n            </p>\n          </FadeIn>\n        </div>\n\n        {/* Layout Grid */}\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-12 pt-4\">\n          \n          {/* Info cards (4 Columns) */}\n          <div className=\"lg:col-span-4 space-y-6\">\n            <FadeIn direction=\"right\" delay={0.1}>\n              <h2 className=\"text-xl font-display font-bold text-white\">Contact Handles</h2>\n            </FadeIn>\n\n            <FadeIn direction=\"right\" delay={0.2}>\n              <div className=\"glass-panel p-6 rounded-2xl border-white/5 bg-surface-card space-y-6\">\n                \n                {/* Email Direct link */}\n                <a\n                  id=\"direct-email-card\"\n                  href={`mailto:${profile.socials.email}`}\n                  className=\"flex items-center gap-4 p-3 rounded-xl border border-white/5 hover:border-brand-primary/20 hover:bg-white/5 transition-all duration-300 group\"\n                >\n                  <div className=\"p-3 rounded-lg bg-brand-primary/10 text-brand-primary group-hover:bg-brand-primary group-hover:text-black transition-colors duration-300\">\n                    <Mail className=\"w-5 h-5\" />\n                  </div>\n                  <div>\n                    <h3 className=\"text-xs font-mono font-bold uppercase tracking-wider text-text-muted\">Direct Email</h3>\n                    <p className=\"text-sm font-semibold text-white tracking-wide group-hover:text-brand-primary transition-colors\">{profile.socials.email}</p>\n                  </div>\n                </a>\n\n                {/* GitHub link */}\n                <a\n                  id=\"social-github-contact\"\n                  href={profile.socials.github}\n                  target=\"_blank\"\n                  referrerPolicy=\"no-referrer\"\n                  className=\"flex items-center gap-4 p-3 rounded-xl border border-white/5 hover:border-brand-primary/20 hover:bg-white/5 transition-all duration-300 group\"\n                >\n                  <div className=\"p-3 rounded-lg bg-white/5 text-text-muted group-hover:bg-brand-primary group-hover:text-black transition-colors duration-300\">\n                    <Github className=\"w-5 h-5\" />\n                  </div>\n                  <div>\n                    <h3 className=\"text-xs font-mono font-bold uppercase tracking-wider text-text-muted\">Github Coordinates</h3>\n                    <p className=\"text-sm font-semibold text-white tracking-wide group-hover:text-brand-primary transition-colors\">github.com/mohdirsath1997</p>\n                  </div>\n                </a>\n\n                {/* LinkedIn Link */}\n                <a\n                  id=\"social-linkedin-contact\"\n                  href={profile.socials.linkedin}\n                  target=\"_blank\"\n                  referrerPolicy=\"no-referrer\"\n                  className=\"flex items-center gap-4 p-3 rounded-xl border border-white/5 hover:border-brand-primary/20 hover:bg-white/5 transition-all duration-300 group\"\n                >\n                  <div className=\"p-3 rounded-lg bg-white/5 text-text-muted group-hover:bg-brand-primary group-hover:text-black transition-colors duration-300\">\n                    <Linkedin className=\"w-5 h-5\" />\n                  </div>\n                  <div>\n                    <h3 className=\"text-xs font-mono font-bold uppercase tracking-wider text-text-muted\">LinkedIn Stream</h3>\n                    <p className=\"text-sm font-semibold text-white tracking-wide group-hover:text-brand-primary transition-colors\">mohamed-irsath-kareem</p>\n                  </div>\n                </a>\n\n                {/* Medium Pub link */}\n                <a\n                  id=\"social-medium-contact\"\n                  href={profile.socials.medium}\n                  target=\"_blank\"\n                  referrerPolicy=\"no-referrer\"\n                  className=\"flex items-center gap-4 p-3 rounded-xl border border-white/5 hover:border-brand-primary/20 hover:bg-white/5 transition-all duration-300 group\"\n                >\n                  <div className=\"p-3 rounded-lg bg-white/5 text-text-muted group-hover:bg-brand-primary group-hover:text-black transition-colors duration-300\">\n                    <MessageSquare className=\"w-5 h-5\" />\n                  </div>\n                  <div>\n                    <h3 className=\"text-xs font-mono font-bold uppercase tracking-wider text-text-muted\">Medium Space</h3>\n                    <p className=\"text-sm font-semibold text-white tracking-wide group-hover:text-brand-primary transition-colors\">@mohdirsath1997</p>\n                  </div>\n                </a>\n\n              </div>\n            </FadeIn>\n          </div>\n\n          {/* Contact form (8 Columns) */}\n          <div className=\"lg:col-span-8\">\n            <FadeIn direction=\"left\" delay={0.15}>\n              <div className=\"glass-panel p-6 sm:p-10 rounded-3xl border-white/5 bg-surface-card shadow-2xl relative min-h-[480px] flex flex-col justify-center\">\n                \n                <AnimatePresence mode=\"wait\">\n                  {!isSuccess ? (\n                    <motion.form\n                      key=\"contact-form\"\n                      id=\"contact-message-form\"\n                      onSubmit={handleSend}\n                      className=\"space-y-6\"\n                      exit={{ opacity: 0, scale: 0.95 }}\n                      transition={{ duration: 0.25 }}\n                    >\n                      <h3 className=\"text-lg font-display font-bold text-white border-b border-white/5 pb-4\">Send Secure Transmission</h3>\n\n                      <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-6\">\n                        {/* Name Line */}\n                        <div className=\"space-y-1.5\">\n                          <label htmlFor=\"input-name\" className=\"text-xs font-mono text-text-muted uppercase tracking-wider\">Your Identity Name</label>\n                          <input\n                            id=\"input-name\"\n                            type=\"text\"\n                            value={name}\n                            onChange={(e) => {\n                              setName(e.target.value);\n                              if (errors.name) setErrors(prev => ({ ...prev, name: \'\' }));\n                            }}\n                            className={`w-full p-3.5 rounded-xl bg-black/40 border text-sm text-white placeholder-text-muted/40 focus:outline-none focus:ring-1 transition-all ${\n                              errors.name ? \'border-red-500/50 focus:ring-red-500/50\' : \'border-white/5 focus:border-brand-primary/50 focus:ring-brand-primary/30\'\n                            }`}\n                            placeholder=\"e.g. Alan Turing\"\n                            disabled={isSubmitting}\n                          />\n                          {errors.name && (\n                            <span className=\"text-[11px] text-red-400 font-mono flex items-center gap-1\">\n                              <AlertCircle className=\"w-3 h-3\" /> {errors.name}\n                            </span>\n                          )}\n                        </div>\n\n                        {/* Email entry */}\n                        <div className=\"space-y-1.5\">\n                          <label htmlFor=\"input-email\" className=\"text-xs font-mono text-text-muted uppercase tracking-wider\">Mailing Address</label>\n                          <input\n                            id=\"input-email\"\n                            type=\"email\"\n                            value={email}\n                            onChange={(e) => {\n                              setEmail(e.target.value);\n                              if (errors.email) setErrors(prev => ({ ...prev, email: \'\' }));\n                            }}\n                            className={`w-full p-3.5 rounded-xl bg-black/40 border text-sm text-white placeholder-text-muted/40 focus:outline-none focus:ring-1 transition-all ${\n                              errors.email ? \'border-red-500/50 focus:ring-red-500/50\' : \'border-white/5 focus:border-brand-primary/50 focus:ring-brand-primary/30\'\n                            }`}\n                            placeholder=\"e.g. alan@turingspace.org\"\n                            disabled={isSubmitting}\n                          />\n                          {errors.email && (\n                            <span className=\"text-[11px] text-red-400 font-mono flex items-center gap-1\">\n                              <AlertCircle className=\"w-3 h-3\" /> {errors.email}\n                            </span>\n                          )}\n                        </div>\n                      </div>\n\n                      {/* Subject */}\n                      <div className=\"space-y-1.5\">\n                        <label htmlFor=\"input-subject\" className=\"text-xs font-mono text-text-muted uppercase tracking-wider\">Transmission Purpose</label>\n                        <input\n                          id=\"input-subject\"\n                          type=\"text\"\n                          value={subject}\n                          onChange={(e) => {\n                            setSubject(e.target.value);\n                            if (errors.subject) setErrors(prev => ({ ...prev, subject: \'\' }));\n                          }}\n                          className={`w-full p-3.5 rounded-xl bg-black/40 border text-sm text-white placeholder-text-muted/40 focus:outline-none focus:ring-1 transition-all ${\n                            errors.subject ? \'border-red-500/50 focus:ring-red-500/50\' : \'border-white/5 focus:border-brand-primary/50 focus:ring-brand-primary/30\'\n                          }`}\n                          placeholder=\"e.g. Cross-Platform App Architecture Pipeline\"\n                          disabled={isSubmitting}\n                        />\n                        {errors.subject && (\n                          <span className=\"text-[11px] text-red-400 font-mono flex items-center gap-1\">\n                            <AlertCircle className=\"w-3 h-3\" /> {errors.subject}\n                          </span>\n                        )}\n                      </div>\n\n                      {/* Message body */}\n                      <div className=\"space-y-1.5\">\n                        <label htmlFor=\"input-message\" className=\"text-xs font-mono text-text-muted uppercase tracking-wider\">Detailed Message Stream</label>\n                        <textarea\n                          id=\"input-message\"\n                          value={message}\n                          onChange={(e) => {\n                            setMessage(e.target.value);\n                            if (errors.message) setErrors(prev => ({ ...prev, message: \'\' }));\n                          }}\n                          className={`w-full p-3.5 rounded-xl bg-black/40 border text-sm text-white placeholder-text-muted/40 h-36 focus:outline-none focus:ring-1 transition-all resize-none ${\n                            errors.message ? \'border-red-500/50 focus:ring-red-500/50\' : \'border-white/5 focus:border-brand-primary/50 focus:ring-brand-primary/30\'\n                          }`}\n                          placeholder=\"Provide details about your project timeline or query...\"\n                          disabled={isSubmitting}\n                        />\n                        {errors.message && (\n                          <span className=\"text-[11px] text-red-400 font-mono flex items-center gap-1\">\n                            <AlertCircle className=\"w-3 h-3\" /> {errors.message}\n                          </span>\n                        )}\n                      </div>\n\n                      {/* Submit */}\n                      <button\n                        id=\"contact-submit-btn\"\n                        type=\"submit\"\n                        disabled={isSubmitting}\n                        className=\"inline-flex items-center gap-2 px-6 py-3.5 bg-brand-primary text-black font-semibold rounded-xl hover:bg-brand-primary/95 hover:scale-[1.01] active:scale-95 transition-all duration-300 font-sans shadow-lg shadow-brand-primary/10 disabled:opacity-50\"\n                      >\n                        {isSubmitting ? (\n                          <>\n                            <div className=\"w-4 h-4 border-2 border-black border-t-transparent rounded-full animate-spin\" />\n                            <span>Validating Cryptographic Stream...</span>\n                          </>\n                        ) : (\n                          <>\n                            <Send className=\"w-4 h-4\" />\n                            <span>Transmit Message</span>\n                          </>\n                        )}\n                      </button>\n\n                    </motion.form>\n                  ) : (\n                    <motion.div\n                      key=\"success-notification\"\n                      id=\"contact-success-notification\"\n                      initial={{ opacity: 0, scale: 0.95 }}\n                      animate={{ opacity: 1, scale: 1 }}\n                      transition={{ type: \'spring\', stiffness: 200, damping: 20 }}\n                      className=\"text-center py-8 space-y-5 px-4\"\n                    >\n                      <CheckCircle2 className=\"w-16 h-16 text-brand-primary mx-auto animate-pulse\" />\n                      \n                      <div className=\"space-y-2\">\n                        <h3 className=\"text-2xl font-display font-bold text-white\">Transmission Sealed!</h3>\n                        <p className=\"text-sm text-text-muted leading-relaxed max-w-md mx-auto font-sans\">\n                          Thank you for reaching out! Mohamed&apos;s connection channels received your secure dispatch. We will finalize review and reply back within a business routing cycle.\n                        </p>\n                      </div>\n\n                      <button\n                        id=\"contact-reset-btn\"\n                        onClick={() => setIsSuccess(false)}\n                        className=\"px-4 py-2 text-xs font-semibold uppercase tracking-wider rounded-xl border border-white/5 hover:border-brand-primary/30 bg-surface hover:text-brand-primary transition-all duration-300\"\n                      >\n                        Reset Terminal\n                      </button>\n                    </motion.div>\n                  )}\n                </AnimatePresence>\n\n              </div>\n            </FadeIn>\n          </div>\n\n        </div>\n\n      </div>\n    </div>\n  );\n};\nexport default Contact;\n"
    }
